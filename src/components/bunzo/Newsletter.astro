---
import { readData } from '../../lib/readData';

const homeConfig = readData('home.json');
const newsletter = homeConfig.newsletter || {};

if (!newsletter.show) return null;
---

<div class="newsletter-area py-section">
  <div class="container mx-auto px-4 relative">
    <div class="lg:grid grid-cols-12 py-10 px-6 md:p-16 rounded-[10px] bg-primary items-center text-center lg:text-left gap-8">
      <div class="col-span-12 lg:col-span-4">
        <h3 class="text-2xl lg:text-[28px] font-bold mb-4 lg:mb-0 text-white font-heading">
          {newsletter.title || "Assine nossa Newsletter"}
        </h3>
        <p class="text-white/80 text-sm lg:text-base mt-2">
          {newsletter.description || "Receba as últimas novidades diretamente no seu e-mail."}
        </p>
      </div>
      <div class="col-span-12 lg:col-span-8">
        <form class="sm:flex block gap-4" onsubmit="return false;">
          <input 
            type="email" 
            placeholder={newsletter.placeholder || "Seu melhor e-mail"} 
            required 
            class="border-2 border-white/20 w-full p-4 rounded-lg bg-white/10 focus:bg-white/20 focus:border-white focus:outline-none text-white text-lg placeholder:text-white/60 transition-all mb-4 sm:mb-0"
          >
          <button 
            type="submit"
            class="bg-white text-primary px-8 py-4 font-bold rounded-lg hover:bg-gray-100 transition-all min-w-max w-full sm:w-auto shadow-lg"
          >
            {newsletter.btnText || "Inscrever Agora"}
          </button>
        </form>
      </div>
    </div>
  </div>
</div>
