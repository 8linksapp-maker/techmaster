---
import { getCollection } from 'astro:content';
import { readData } from '../../lib/readData';

const homeConfig = readData('home.json');
const trendingConfig = homeConfig.trending || {};

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const trendingPosts = allPosts.slice(0, trendingConfig.limit || 6);

function formatDate(date: Date) {
  return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
}
---

<div class="trending py-section bg-white">
  <div class="container mx-auto px-4">
    <h2 class="text-2xl font-bold mb-12 leading-6 font-heading text-heading">{trendingConfig.title || "Artigos em Alta"}</h2>
    <div class="grid lg:grid-cols-2 gap-9">
      {trendingPosts.map(post => (
        <article class="post md:flex items-center group">
          <div class="post-image md:w-[250px] w-full flex-shrink-0 flex-grow-0 rounded-[10px] overflow-hidden relative h-[180px]">
            <a href={`/blog/${post.slug}`}>
              <img 
                src={post.data.heroImage || "/assets/bunzo/images/posts/1.jpg"} 
                alt={post.data.title} 
                class="object-cover h-full w-full group-hover:scale-110 transition-all duration-500"
              >
            </a>
          </div>
          <div class="post-info md:pl-7 md:mt-0 mt-5 flex-1">
            <div class="flex items-center text-sm">
              {post.data.category && (
                <a 
                  href={`/categoria/${post.data.category.toLowerCase().replace(/[^a-z0-9]/g, '-')}`} 
                  class="category bg-[#edebf5] capitalize rounded-md px-3 py-1 mr-2 hover:bg-primary hover:text-white transition-colors"
                >
                  {post.data.category}
                </a>
              )}
              <div class="date flex items-center ml-4 text-gray-400">
                <i class="icofont-ui-calendar mr-2"></i>
                <p class="mb-0">{formatDate(post.data.pubDate)}</p>
              </div>
            </div>
            <h3 class="mb-0 text-lg font-bold !leading-snug pt-2 md:pt-4 hover:text-primary transition-colors">
              <a href={`/blog/${post.slug}`}>{post.data.title}</a>
            </h3>
          </div>
        </article>
      ))}
    </div>
  </div>
</div>
