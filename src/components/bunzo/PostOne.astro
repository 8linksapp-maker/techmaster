---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

import { readData } from '../../lib/readData';
const authors = readData('authors.json', []);

function formatDate(date: Date) {
  return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
}

// Estimativa simples de tempo de leitura
const readingTime = Math.ceil(post.body.split(' ').length / 200);
---

<article class="post md:flex items-center group bg-white rounded-[10px] overflow-hidden">
  <div class="post-image overflow-hidden rounded-[10px] xl:w-[530px] md:w-[400px] h-[200px] md:h-[265px] flex-shrink-0 relative">
    <a href={`/blog/${post.slug}`}>
      <img 
        src={post.data.heroImage || "/assets/bunzo/images/posts/1.jpg"} 
        alt={post.data.title} 
        class="object-cover h-full w-full group-hover:scale-110 transition-all duration-500"
      >
      {/* Ícone de vídeo opcional se houver metadado de vídeo no futuro */}
    </a>
  </div>
  
  <div class="post-info md:pl-7 md:mt-0 mt-10 flex-1">
    <div class="flex items-center text-[13px] md:text-base">
      {post.data.category && (
        <a 
          href={`/categoria/${post.data.category.toLowerCase().replace(/[^a-z0-9]/g, '-')}`} 
          class="category bg-[#edebf5] capitalize rounded-md px-4 py-1.5 mr-2 hover:bg-primary hover:text-white transition-colors"
        >
          {post.data.category}
        </a>
      )}
      <div class="author ml-4 md:ml-6 flex items-center">
        <span class="text-[#9b9ea1] mr-1">By</span>
        {(() => {
          const a = authors.find((au: any) => au.id === post.data.author) || { name: post.data.author || 'Admin' };
          return <a href={`/autor/${a.name.toLowerCase().replace(/ /g, '-')}`} class="hover:text-primary font-medium transition-colors">{a.name}</a>;
        })()}
      </div>
    </div>
    
    <h2 class="text-lg md:text-2xl font-bold pt-4 md:pt-6 mb-0 hover:text-primary leading-snug transition-colors">
      <a href={`/blog/${post.slug}`}>{post.data.title}</a>
    </h2>
    
    <p class="mt-4 text-gray-500 line-clamp-2 md:line-clamp-3 leading-relaxed">
      {post.data.description}
    </p>
    
    <div class="meta flex items-center mt-4 md:mt-5 text-sm text-gray-400">
      <div class="flex items-center">
        <i class="icofont-ui-calendar mr-2"></i>
        <p class="mb-0">{formatDate(post.data.pubDate)}</p>
      </div>
      <div class="flex items-center pl-5">
        <i class="icofont-clock-time mr-2"></i>
        <p class="mb-0">{readingTime} min read</p>
      </div>
    </div>
  </div>
</article>
